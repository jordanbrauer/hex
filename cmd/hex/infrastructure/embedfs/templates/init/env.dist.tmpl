# Environment variables for {{.Name}}. Copy to .env and edit as needed.
# The mapping between env vars and config keys lives in config/env.yaml.
LOG_LEVEL=info
{{ if eq .Dialect "postgres" -}}
DATABASE_DSN=postgres://localhost:5432/{{.BinaryName}}?sslmode=disable
{{ end -}}
{{ if eq .AI "openai" -}}
OPENAI_API_KEY=
{{ end -}}
{{ if eq .AI "anthropic" -}}
ANTHROPIC_API_KEY=
{{ end -}}
