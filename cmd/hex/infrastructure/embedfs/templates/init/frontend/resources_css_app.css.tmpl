@import "tailwindcss";

/* Tailwind v4 CSS-first configuration. Declare template + JS source
 * paths so the utility scanner picks up class references. Add
 * additional @source lines as your view/js layout grows.
 */
@source "../../web/views/**/*.gotmpl";
{{- if .FrontendTS }}
@source "../../resources/js/**/*.{ts,tsx}";
{{- else }}
@source "../../public/js/**/*.js";
{{- end }}

