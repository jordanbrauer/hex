package provider

import (
	"github.com/jordanbrauer/hex/db/lua/provider"
)

// LuaDB installs the `db` Lua module into the shared hex/lua env, so
// scripts and the REPL (`{{.BinaryName}} repl`) can call:
//
//	local db = require("db")
//	local rows, err = db.query("SELECT * FROM users WHERE id = ?", 1)
//	local u, err = db.queryOne("SELECT * FROM users WHERE id = ?", 1)
//	db.exec("UPDATE users SET name = ? WHERE id = ?", "Bob", 1)
//	db.transaction(function(tx)
//	    tx.exec("...")
//	    tx.exec("...")
//	end)
//
// Wired after Database() and Lua() so both bindings exist when this
// provider's Register runs.
func LuaDB() *provider.Provider {
	return &provider.Provider{}
}
