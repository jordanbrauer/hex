package provider

import (
	"context"
	"database/sql"

	{{ if eq .Dialect "sqlite" -}}
	_ "modernc.org/sqlite"
	{{- else if eq .Dialect "postgres" -}}
	_ "github.com/lib/pq"
	{{- end }}

	"github.com/jordanbrauer/hex"
	"github.com/jordanbrauer/hex/container"
	hexdb "github.com/jordanbrauer/hex/db"
	{{ if eq .Dialect "sqlite" -}}
	hexsqlite "github.com/jordanbrauer/hex/db/sqlite"
	{{- else if eq .Dialect "postgres" -}}
	hexpostgres "github.com/jordanbrauer/hex/db/postgres"
	{{- end }}
	"github.com/jordanbrauer/hex/provider"

	"{{.ModulePath}}/db"
)

// Database opens the primary SQL connection and runs pending migrations.
// The connection is bound in the container as "db" and can be resolved
// via container.Must[*sql.DB](app, "db").
type Database struct {
	provider.Base

	db *sql.DB
}

// Register binds the database connection lazily. Actual opening happens
// during Boot.
func (p *Database) Register(app provider.Application) error {
	app.Singleton("db", func(*container.Container) (any, error) {
		return p.db, nil
	})

	return nil
}

// Boot opens the connection and runs migrations.
func (p *Database) Boot(ctx context.Context, app provider.Application) error {
	conn, err := hexdb.Open(ctx, hexdb.Config{
		Driver: "{{.Dialect}}",
		DSN:    "{{ if eq .Dialect "sqlite" }}./data/{{.BinaryName}}.db{{ else }}postgres://localhost:5432/{{.BinaryName}}?sslmode=disable{{ end }}",
	})
	if err != nil {
		return err
	}

	{{ if eq .Dialect "sqlite" -}}
	if err := hexsqlite.Migrate(conn, db.Migrations, db.MigrationsDir); err != nil {
		return err
	}
	{{- else if eq .Dialect "postgres" -}}
	if err := hexpostgres.Migrate(conn, db.Migrations, db.MigrationsDir); err != nil {
		return err
	}
	{{- end }}

	p.db = conn

	return nil
}

// Shutdown closes the connection.
func (p *Database) Shutdown(ctx context.Context, app provider.Application) error {
	if p.db == nil {
		return nil
	}

	return p.db.Close()
}

// compile-time confirmation the provider participates in shutdown.
var _ provider.Shutdowner = (*Database)(nil)

// silence the unused-import warnings for the hex.App type; some future
// generator additions will use it.
var _ = (*hex.App)(nil)
