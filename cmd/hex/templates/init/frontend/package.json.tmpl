{
    "name": "{{.BinaryName}}",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@9.15.0",
    "description": "Frontend deps for {{.Name}}. Task orchestration lives in the justfile — run `just` to list recipes; `just dev-fe`, `just build-fe`, `just lint-fe`, etc. call the tools installed here via `pnpm exec`.",
    "dependencies": {
        "alpinejs": "^3.14.9",
        "htmx.org": "^2.0.4"
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.4",
{{- if .FrontendTS }}
        "@tailwindcss/vite": "^4.0.0",
        "@types/alpinejs": "^3.13.11",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.7.2",
        "vite": "^6.0.0",
{{- else }}
        "@tailwindcss/cli": "^4.0.0",
        "cpy-cli": "^5.0.0",
        "tailwindcss": "^4.0.0",
{{- end }}
        "vitest": "^2.1.8"
    }
}
